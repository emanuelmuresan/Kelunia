          "deletedByUid"
        ])
        && data.dayIndex is int
        && data.dayIndex >= 0
        && data.dayIndex <= 6
        && validText(data.group, 120)
        && validText(data.room, 120)
        && validTime(data.startTime)
        && validTime(data.endTime)
