    function validAuditEntityType(entityType) {
      return entityType == "booking"
        || entityType == "fixedSchedule"
        || entityType == "room"
        || entityType == "group"
        || entityType == "accessCode"
        || entityType == "user"
        || entityType == "location"
        || entityType == "license"
        || entityType == "settings"
        || entityType == "floorplan"
        || entityType == "floorplanItem";
    }

    function validAuditAction(action) {
      return action == "create"
        || action == "update"
        || action == "delete";
    }

    function validAuditSnapshot(value) {
      return value == null
        || value is map;
    }

    function validAuditLogData(data) {
      return data.keys().hasOnly([
          "locationId",
          "locationName",
          "entityType",
          "entityId",
