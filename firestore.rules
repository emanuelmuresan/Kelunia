    function validFloorplanItemType(value) {
      return value == "room"
        || value == "circle"
        || value == "asset"
        || value == "wall"
        || value == "door"
        || value == "window"
        || value == "text";
    }

    function validFloorplanAssetType(value) {
      return value == "table"
        || value == "chair"
        || value == "desk"
        || value == "sofa"
        || value == "bed"
        || value == "tv"
        || value == "sink"
        || value == "toilet"
        || value == "cabinet"
        || value == "appliance"
        || value == "equipment"
        || value == "storage"
        || value == "custom";
    }

    function validFloorplanItemStatus(value) {
      return value == "available"
        || value == "occupied"
        || value == "maintenance"
        || value == "broken";
    }

    function floorplanPath(floorplanId) {
      return /databases/$(database)/documents/floorplans/$(floorplanId);
    }

    function floorplanBelongsToLocation(floorplanId, locationId) {
      return floorplanId is string
        && floorplanId.size() > 0
        && exists(floorplanPath(floorplanId))
        && get(floorplanPath(floorplanId)).data.locationId == locationId;
    }

    function validFloorplanReference(data) {
      return validText(data.floorplanId, 160)
        && (
          !exists(floorplanPath(data.floorplanId))
          || floorplanBelongsToLocation(data.floorplanId, data.locationId)
          || canWriteFloorplanLocation(data.locationId)
        );
    }

    function validOptionalNumber(data, key) {
      return !hasKey(data, key)
        || validNumber(data[key]);
    }

    function validOptionalCoordinate(data, key) {
      return !hasKey(data, key)
        || validCoordinate(data[key]);
    }

    function validOptionalNumberList(data, key, maxSize) {
      return !hasKey(data, key)
        || (
          data[key] is list
          && data[key].size() <= maxSize
        );
    }

    function validOptionalStringList(data, key, maxSize) {
      return !hasKey(data, key)
        || (
          data[key] is list
          && data[key].size() <= maxSize
        );
    }

    function validOptionalItemMetadata(data) {
      return !hasKey(data, "metadata")
        || data.metadata is map;
    }

    function validFloorplanItemCreateOrUpdate(data) {
      return validFloorplanItemData(data)
        || (
          data.keys().hasOnly([
            "locationId",
            "locationName",
