            "points",
            "tags",
            "zIndex",
            "locked",
            "visible",
            "metadata",
            "createdBy",
            "createdByUid",
            "createdAt",
            "updatedBy",
            "updatedByUid",
            "updatedAt",
            "deleted",
            "deletedAt",
            "deletedBy",
            "deletedByUid"
          ])
          && validText(data.locationId, 160)
          && validOptionalText(data, "locationName", 300)
          && validFloorplanReference(data)
          && validFloorplanItemType(data.type)
          && validOptionalText(data, "name", 160)
          && validOptionalText(data, "label", 160)
          && validCoordinate(data.x)
          && validCoordinate(data.y)
          && validOptionalCoordinate(data, "startX")
          && validOptionalCoordinate(data, "startY")
          && validOptionalCoordinate(data, "endX")
          && validOptionalCoordinate(data, "endY")
          && validPositiveNumber(data.width)
          && validPositiveNumber(data.height)
          && validOptionalPositiveNumber(data, "radius")
          && validOptionalNumber(data, "rotation")
          && validOptionalText(data, "color", 32)
          && validOptionalText(data, "icon", 80)
          && validOptionalText(data, "category", 80)
          && validOptionalText(data, "linkedRoomId", 160)
          && validOptionalText(data, "linkedAssetId", 160)
          && validOptionalText(data, "roomId", 160)
