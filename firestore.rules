          "updatedByUid"
        ])
        && request.resource.data.email == resource.data.email
        && request.resource.data.organizationName == resource.data.organizationName
        && request.resource.data.details == resource.data.details
        && request.resource.data.source == resource.data.source
        && request.resource.data.createdAt == resource.data.createdAt
        && validCommunityApplicationStatus(request.resource.data.status)
        && validOptionalTimestamp(request.resource.data, "reviewedAt")
        && validOptionalText(request.resource.data, "reviewedBy", 180)
        && validOptionalText(request.resource.data, "reviewedByUid", 160)
        && validOptionalTimestamp(request.resource.data, "lastReplyAt")
        && validOptionalTimestamp(request.resource.data, "updatedAt")
        && validOptionalText(request.resource.data, "updatedBy", 180)
        && validOptionalText(request.resource.data, "updatedByUid", 160)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "reviewedAt",
          "reviewedBy",
          "reviewedByUid",
          "lastReplyAt",
          "updatedAt",
          "updatedBy",
          "updatedByUid"
        ]);
    }

    function validCommunityApplicationMessageData(applicationId, data) {
      return signedInVerified()
        && isOwner()
        && data.keys().hasOnly([
          "applicationId",
          "body",
          "direction",
          "deliveryStatus",
          "fromEmail",
          "fromUid",
          "toEmail",
          "createdAt",
          "sentAt",
          "failedAt",
          "resendEmailId",
          "errorMessage"
        ])
        && data.applicationId == applicationId
        && validText(data.body, 4000)
        && data.direction == "outbound"
        && data.deliveryStatus == "pending"
        && data.fromEmail == request.auth.token.email
        && data.fromUid == request.auth.uid
        && validText(data.toEmail, 180)
        && data.createdAt == request.time
        && !hasKey(data, "sentAt")
        && !hasKey(data, "failedAt")
        && !hasKey(data, "resendEmailId")
        && !hasKey(data, "errorMessage");
    }

    function validNewsletterSubscriberPublicWrite(subscriberId, data) {
      return data.keys().hasOnly([
          "email",
          "emailKey",
          "source",
          "status",
          "unsubscribed",
          "createdAt",
          "updatedAt"
        ])
        && validText(data.email, 180)
        && validText(data.emailKey, 240)
        && data.emailKey == subscriberId
        && data.source == "landing-newsletter"
        && data.status == "active"
        && data.unsubscribed == false
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function validNewsletterCampaignCreate(data) {
      return signedInVerified()
        && isOwner()
        && data.keys().hasOnly([
          "subject",
          "body",
          "status",
          "recipientEmail",
          "createdAt",
          "createdBy",
          "createdByUid"
        ])
        && validText(data.subject, 180)
        && validText(data.body, 6000)
        && validOptionalText(data, "recipientEmail", 180)
        && data.status == "pending"
        && data.createdAt == request.time
        && data.createdBy == request.auth.token.email
        && data.createdByUid == request.auth.uid;
    }

    function validLicenseEmailRequestCreate(data) {
      return signedInVerified()
        && isOwner()
        && data.keys().hasOnly([
          "licenseId",
          "code",
          "toEmail",
          "message",
          "status",
          "createdAt",
          "createdBy",
          "createdByUid"
        ])
        && validText(data.licenseId, 80)
        && validText(data.code, 80)
        && data.licenseId == data.code
        && exists(licensePath(data.licenseId))
        && get(licensePath(data.licenseId)).data.active == true
        && get(licensePath(data.licenseId)).data.claimed != true
        && get(licensePath(data.licenseId)).data.used != true
        && get(licensePath(data.licenseId)).data.deleted != true
        && validText(data.toEmail, 180)
        && validTextOrEmpty(data.message, 2000)
        && data.status == "pending"
        && data.createdAt == request.time
        && data.createdBy == request.auth.token.email
        && data.createdByUid == request.auth.uid;
    }

    function validSubscriptionData(data) {
      return data.keys().hasOnly([
          "locationId",
          "locationName",
          "plan",
          "billingStatus",
          "provider",
          "providerCustomerId",
          "providerSubscriptionId",
          "currentPeriodStart",
          "currentPeriodEnd",
          "cancelAtPeriodEnd",
          "createdAt",
          "updatedAt",
          "updatedBy"
        ])
        && validText(data.locationId, 160)
        && validTextOrEmpty(data.locationName, 180)
        && validLocationPlan(data.plan)
        && validBillingStatus(data.billingStatus)
        && validOptionalText(data, "provider", 80)
        && validOptionalText(data, "providerCustomerId", 180)
        && validOptionalText(data, "providerSubscriptionId", 180)
        && (!hasKey(data, "currentPeriodStart") || validNullableTimestamp(data.currentPeriodStart))
        && (!hasKey(data, "currentPeriodEnd") || validNullableTimestamp(data.currentPeriodEnd))
        && (!hasKey(data, "cancelAtPeriodEnd") || data.cancelAtPeriodEnd is bool)
        && validOptionalTimestamp(data, "createdAt")
        && validOptionalTimestamp(data, "updatedAt")
        && validOptionalText(data, "updatedBy", 180);
    }

    match /users/{userId} {
      allow read: if signedInVerified()
        && (
          isOwner()
          || request.auth.uid == userId
          || resource.data.locationId == userLocationId()
        );

      allow create: if validUserCreate(userId);

      allow update: if signedInVerified()
        && validUserDataShape(request.resource.data)
        && (
          validOwnerSyncUpdate(userId)
          || validOwnUserUpdate(userId)
          || validLocationSetupUserUpdate(userId)
          || validManagerUserUpdate()
        );

      allow delete: if signedInVerified()
        && resource.data.isOwner != true
        && (
          isOwner()
          || (
            isLocationSuperAdmin()
            && resource.data.locationId == userLocationId()
          )
        );
    }

    match /settings/auth_codes {
      allow read, write: if false;
    }

    match /accessCodes/{codeId} {
      allow get: if true;
      allow list: if signedInVerified()
        && (
          isOwner()
          || (
            isLocationSuperAdmin()
            && resource.data.locationId == userLocationId()
          )
        );
      allow create: if (
          isOwner()
          || (
            isLocationSuperAdmin()
            && request.resource.data.locationId == userLocationId()
          )
        )
        && locationWriteEnabled(request.resource.data.locationId)
        && request.resource.data.code == codeId
        && validAccessRole(request.resource.data.role)
        && validAccessGroup(request.resource.data.role, request.resource.data.groupName)
        && validAccessUsage(
          request.resource.data.role,
          request.resource.data.maxUses,
          request.resource.data.usedCount,
          request.resource.data.active
        )
        && request.resource.data.keys().hasOnly([
          "code",
          "role",
          "groupName",
          "roomAccess",
          "allowedRoomIds",
          "locationId",
          "locationName",
          "maxUses",
          "usedCount",
          "active",
          "createdBy",
          "createdAt",
          "deleted"
        ])
        && validText(request.resource.data.locationName, 180)
        && validRoomAccessData(request.resource.data.role, request.resource.data)
        && validTextOrEmpty(request.resource.data.createdBy, 180)
        && request.resource.data.createdAt is timestamp
        && validSoftDeleteFields(request.resource.data);
      allow update: if validAccessCodeSoftDeleteUpdate()
        || (
          (
            isOwner()
            || (
              isLocationSuperAdmin()
              && resource.data.locationId == userLocationId()
            )
          )
          && locationWriteEnabled(resource.data.locationId)
          && request.resource.data.locationId == resource.data.locationId
          && request.resource.data.code == resource.data.code
          && validText(request.resource.data.locationName, 180)
          && validAccessRole(request.resource.data.role)
          && validAccessGroup(request.resource.data.role, request.resource.data.groupName)
          && validRoomAccessData(request.resource.data.role, request.resource.data)
          && validAccessUsage(
            request.resource.data.role,
            request.resource.data.maxUses,
            request.resource.data.usedCount,
            request.resource.data.active
          )
          && validSoftDeleteFields(request.resource.data)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "role",
            "groupName",
            "roomAccess",
            "allowedRoomIds",
            "locationName",
            "maxUses",
            "usedCount",
            "active",
            "updatedBy",
            "updatedAt",
            "deleted",
            "deletedAt",
            "deletedBy",
            "deletedByUid"
          ])
        )
        || validAccessUseUpdate(codeId);
      allow delete: if (
          isOwner()
          || (
            isLocationSuperAdmin()
            && resource.data.locationId == userLocationId()
          )
        )
        && locationWriteEnabled(resource.data.locationId);
    }

    match /settings/{settingId} {
      allow read: if signedInVerified()
        && settingId != "auth_codes"
        && (
          isOwner()
          || resource.data.locationId == userLocationId()
        );
      allow create, update: if settingId != "auth_codes"
        && (
          isOwner()
          || isLocationSuperAdmin()
        )
        && validSettingsData(request.resource.data)
        && (
          isOwner()
          || request.resource.data.locationId == userLocationId()
        )
        && locationWriteEnabled(request.resource.data.locationId);
      allow delete: if settingId != "auth_codes"
        && (
          isOwner()
          || (
            isLocationSuperAdmin()
            && resource.data.locationId == userLocationId()
          )
        );
    }

    match /licenses/{licenseId} {
      allow get: if (
          signedInVerified()
          && (
            isOwner()
            || hasPendingLicense()
            || resource.data.claimedByUid == request.auth.uid
          )
        )
        || (
          !signedIn()
          && resource.data.active == true
          && resource.data.used != true
          && resource.data.claimed != true
          && resource.data.deleted != true
        );
      allow list: if signedInVerified() && isOwner();
      allow create: if signedInVerified()
        && isOwner()
        && request.resource.data.code == licenseId
        && validLicenseData(request.resource.data);
      allow delete: if signedInVerified() && isOwner();
      allow update: if validLicenseActiveToggleUpdate()
        || (
          signedInVerified()
          && isOwner()
          && validLicenseData(request.resource.data)
        )
        || (
          signedIn()
          && (
            !hasUserDoc()
            || (
              hasPendingLicense()
              && userData().pendingLicenseId == licenseId
            )
          )
          && resource.data.used != true
          && resource.data.claimed != true
          && resource.data.active != false
          && resource.data.deleted != true
          && request.resource.data.claimed == true
          && request.resource.data.claimedByUid == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "claimed",
            "claimedAt",
            "claimedBy",
            "claimedByUid"
          ])
        )
        || (
          signedInVerified()
          && resource.data.claimedByUid == request.auth.uid
          && resource.data.used != true
          && resource.data.active != false
          && resource.data.deleted != true
          && request.resource.data.used == true
          && request.resource.data.usedByUid == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "used",
            "usedAt",
            "usedBy",
            "usedByUid",
            "locationId",
            "locationName",
            "intendedAddress",
            "officialAddress"
          ])
        );
    }

    match /communityApplications/{applicationId} {
      allow create: if validCommunityApplicationData(request.resource.data);
      allow read: if signedInVerified() && isOwner();
      allow update: if validCommunityApplicationOwnerUpdate();
      allow delete: if signedInVerified() && isOwner();

      match /messages/{messageId} {
        allow read: if signedInVerified() && isOwner();
        allow create: if validCommunityApplicationMessageData(applicationId, request.resource.data);
        allow update: if false;
        allow delete: if signedInVerified() && isOwner();
      }
    }

    match /newsletterSubscribers/{subscriberId} {
      allow create, update: if validNewsletterSubscriberPublicWrite(subscriberId, request.resource.data)
        || (signedInVerified() && isOwner());
      allow read, delete: if signedInVerified() && isOwner();
    }

    match /newsletterCampaigns/{campaignId} {
      allow read: if signedInVerified() && isOwner();
      allow create: if validNewsletterCampaignCreate(request.resource.data);
      allow update: if false;
      allow delete: if signedInVerified() && isOwner();

      match /deliveries/{deliveryId} {
        allow read: if signedInVerified() && isOwner();
        allow write: if false;
      }
    }

    match /licenseEmailRequests/{requestId} {
      allow read: if signedInVerified() && isOwner();
      allow create: if validLicenseEmailRequestCreate(request.resource.data);
      allow update: if false;
      allow delete: if signedInVerified() && isOwner();
    }

    match /subscriptions/{subscriptionId} {
      allow read: if signedInVerified()
        && (
          isOwner()
          || (
            resource.data.locationId == userLocationId()
            && isLocationSuperAdmin()
          )
        );
      allow create, update: if signedInVerified()
        && isOwner()
        && validSubscriptionData(request.resource.data);
      allow delete: if signedInVerified() && isOwner();
    }

    match /events/{eventId} {
      allow read: if signedInVerified()
        && (
          isOwner()
          || resource.data.locationId == userLocationId()
        );
      allow create: if isLocationAdmin()
        && validEventData(request.resource.data)
        && request.resource.data.locationId == userLocationId()
        && roomAccessAllows(request.resource.data.roomId)
        && locationWriteEnabled(request.resource.data.locationId);
      allow update: if validEventData(request.resource.data)
        && locationWriteEnabled(resource.data.locationId)
        && roomAccessAllows(request.resource.data.roomId)
        && (
          (
            canManageLocation(resource.data.locationId)
            && request.resource.data.locationId == resource.data.locationId
          )
          || (
            isLocationAdmin()
            && resource.data.locationId == userLocationId()
            && request.resource.data.locationId == resource.data.locationId
            && (
              resource.data.authorEmail == request.auth.token.email
              || resource.data.author == request.auth.token.email
            )
          )
        );
      allow delete: if (canManageLocation(resource.data.locationId) && locationWriteEnabled(resource.data.locationId))
        || (
          isLocationAdmin()
          && resource.data.locationId == userLocationId()
          && locationWriteEnabled(resource.data.locationId)
          && (
            resource.data.authorEmail == request.auth.token.email
            || resource.data.author == request.auth.token.email
          )
        );
    }

    match /rooms/{roomId} {
      allow read: if signedInVerified()
        && (
          isOwner()
          || resource.data.locationId == userLocationId()
        );
      allow create: if canManageLocation(request.resource.data.locationId)
        && locationWriteEnabled(request.resource.data.locationId)
        && validSpaceData(request.resource.data);
      allow update: if canManageLocation(resource.data.locationId)
        && locationWriteEnabled(resource.data.locationId)
        && request.resource.data.locationId == resource.data.locationId
        && validSpaceData(request.resource.data);
      allow delete: if canManageLocation(resource.data.locationId)
        && locationWriteEnabled(resource.data.locationId);
    }

    match /groups/{groupId} {
      allow read: if signedInVerified()
        && (
          isOwner()
          || resource.data.locationId == userLocationId()
        );
      allow create: if canManageLocation(request.resource.data.locationId)
        && locationWriteEnabled(request.resource.data.locationId)
        && validSpaceData(request.resource.data);
      allow update: if canManageLocation(resource.data.locationId)
        && locationWriteEnabled(resource.data.locationId)
        && request.resource.data.locationId == resource.data.locationId
        && validSpaceData(request.resource.data);
      allow delete: if canManageLocation(resource.data.locationId)
        && locationWriteEnabled(resource.data.locationId);
    }

    match /fixedSchedules/{scheduleId} {
      allow read: if signedInVerified()
        && (
          isOwner()
          || resource.data.locationId == userLocationId()
        );
      allow create: if canManageLocation(request.resource.data.locationId)
        && locationWriteEnabled(request.resource.data.locationId)
        && validFixedScheduleData(request.resource.data);
      allow update: if canManageLocation(resource.data.locationId)
        && locationWriteEnabled(resource.data.locationId)
        && request.resource.data.locationId == resource.data.locationId
        && validFixedScheduleData(request.resource.data);
      allow delete: if canManageLocation(resource.data.locationId)
        && locationWriteEnabled(resource.data.locationId);
    }

    match /floorplans/{floorplanId} {
      allow read, write: if false;
    }

    match /floorplanItems/{itemId} {
      allow read, write: if false;
    }

    match /auditLogs/{logId} {
      allow read: if signedInVerified()
        && (
          isOwner()
          || (
            isLocationSuperAdmin()
            && resource.data.locationId == userLocationId()
          )
        );
      allow create: if signedInVerified()
        && validAuditLogData(request.resource.data)
        && (
          isOwner()
          || request.resource.data.locationId == userLocationId()
        );
      allow update, delete: if false;
    }

    match /locations/{locationId} {
      allow get: if signedInVerified()
        && (
          isOwner()
          || locationId == userLocationId()
          || !hasUserDoc()
          || hasPendingLocationSetup()
        );
      allow list: if signedInVerified() && isOwner();
      allow create: if signedInVerified()
        && validLocationCreate();
      allow update: if validOwnerLocationLicenseUpdate()
        || (
          (isOwner() || (canManageLocation(locationId) && locationWriteEnabled(locationId)))
          && validLocationData(request.resource.data)
        );
      allow delete: if isOwner() || (canManageLocation(locationId) && locationWriteEnabled(locationId));
    }
  }
}
