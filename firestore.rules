    function validSettingsData(data) {
      return data.keys().hasOnly([
          "fixedSectionTitle",
          "fixedPageEnabled",
          "listViewTitle",
          "resourcesSectionTitle",
          "roomsLabel",
          "groupsLabel",
          "locationId",
          "locationName",
          "updatedBy",
          "updatedAt"
        ])
        && validText(data.fixedSectionTitle, 80)
        && data.fixedPageEnabled is bool
        && validText(data.listViewTitle, 80)
        && validText(data.resourcesSectionTitle, 80)
        && validText(data.roomsLabel, 60)
        && validText(data.groupsLabel, 60)
        && validText(data.locationId, 160)
        && validTextOrEmpty(data.locationName, 180)
        && validTextOrEmpty(data.updatedBy, 180)
        && data.updatedAt is timestamp;
    }

    function validLocationData(data) {
      return data.keys().hasOnly([
          "name",
          "locationName",
          "address",
          "officialAddress",
          "placeId",
          "ownerEmail",
          "createdBy",
          "createdAt",
          "updatedBy",
          "updatedAt",
          "plan",
          "billingStatus",
          "subscriptionId",
          "subscriptionExpiresAt",
          "trialEndsAt",
          "usage",
          "planLimits",
          "deleted",
          "deletedAt",
          "deletedBy",
          "deletedByUid"
        ])
        && validText(data.name, 180)
        && validOptionalText(data, "locationName", 180)
        && validOptionalText(data, "address", 300)
        && validOptionalText(data, "officialAddress", 300)
        && validOptionalText(data, "placeId", 180)
        && validOptionalText(data, "ownerEmail", 180)
        && validOptionalText(data, "createdBy", 180)
        && validOptionalTimestamp(data, "createdAt")
        && validOptionalText(data, "updatedBy", 180)
        && validOptionalTimestamp(data, "updatedAt")
        && (!hasKey(data, "plan") || validLocationPlan(data.plan))
        && (!hasKey(data, "billingStatus") || validBillingStatus(data.billingStatus))
        && validOptionalText(data, "subscriptionId", 180)
        && (!hasKey(data, "subscriptionExpiresAt") || validNullableTimestamp(data.subscriptionExpiresAt))
        && (!hasKey(data, "trialEndsAt") || validNullableTimestamp(data.trialEndsAt))
        && (!hasKey(data, "usage") || validUsageCounters(data.usage))
        && (!hasKey(data, "planLimits") || validPlanLimits(data.planLimits))
        && validSoftDeleteFields(data);
    }

    function validTrialLocationCreateData(data) {
      return hasPendingTrialSetup()
        && data.plan == "standard"
        && data.billingStatus == "trialing"
        && data.trialEndsAt is timestamp
        && data.trialEndsAt > request.time
        && (!hasKey(data, "subscriptionId") || data.subscriptionId == "")
        && (!hasKey(data, "subscriptionExpiresAt") || data.subscriptionExpiresAt == null);
    }

    function validLocationCreate() {
      return validLocationData(request.resource.data)
        && (
          isOwner()
          || (
            hasPendingLocationSetup()
            && request.resource.data.ownerEmail == request.auth.token.email
            && request.resource.data.createdBy == request.auth.token.email
            && (
              hasPendingLicense()
              || validTrialLocationCreateData(request.resource.data)
            )
          )
        );
    }

    function validOwnerLocationLicenseUpdate() {
      return signedInVerified()
        && isOwner()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "name",
          "plan",
          "billingStatus",
          "subscriptionExpiresAt",
          "trialEndsAt",
          "updatedBy",
          "updatedAt"
        ])
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(["name"])
          || validText(request.resource.data.name, 180)
        )
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(["plan"])
          || validLocationPlan(request.resource.data.plan)
        )
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(["billingStatus"])
          || validBillingStatus(request.resource.data.billingStatus)
        )
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(["subscriptionExpiresAt"])
          || validNullableTimestamp(request.resource.data.subscriptionExpiresAt)
        )
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(["trialEndsAt"])
          || validNullableTimestamp(request.resource.data.trialEndsAt)
        )
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(["updatedBy"])
          || validTextOrEmpty(request.resource.data.updatedBy, 180)
        )
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(["updatedAt"])
          || request.resource.data.updatedAt is timestamp
        );
    }

