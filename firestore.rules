          && validOptionalText(data, "wallId", 160)
          && validOptionalText(data, "attachedWallId", 160)
          && (!hasKey(data, "assetType") || validFloorplanAssetType(data.assetType))
          && (!hasKey(data, "status") || validFloorplanItemStatus(data.status))
          && validOptionalText(data, "notes", 1000)
          && validOptionalText(data, "photoUrl", 2000)
          && validOptionalText(data, "photoPath", 600)
          && validOptionalText(data, "documentUrl", 2000)
          && validOptionalText(data, "documentPath", 600)
          && validOptionalText(data, "documentName", 240)
