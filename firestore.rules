        && validTextOrEmpty(data.locationName, 180)
        && validAuditEntityType(data.entityType)
        && validText(data.entityId, 180)
        && validAuditAction(data.action)
        && data.actorUid == request.auth.uid
        && data.actorEmail == request.auth.token.email
        && validText(data.actorName, 120)
        && validAuditSnapshot(data.before)
        && validAuditSnapshot(data.after)
        && data.createdAt is timestamp;
    }

    function validCommunityApplicationStatus(status) {
      return status == "new"
        || status == "reviewed"
        || status == "replied"
        || status == "approved"
        || status == "declined";
    }

    function validCommunityApplicationSource(source) {
      return source == "landing-community"
        || source == "landing-newsletter"
        || source == "landing-contact";
    }

    function validCommunityApplicationData(data) {
      return data.keys().hasOnly([
